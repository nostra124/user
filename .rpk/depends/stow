#!/bin/sh
# Install dependency: stow (system tool).
set -eu

command -v stow >/dev/null 2>&1 && exit 0

# Common Homebrew locations on macOS
BREW=""
[ -x /opt/homebrew/bin/brew ] && BREW=/opt/homebrew/bin/brew
[ -x /usr/local/bin/brew ] && BREW=/usr/local/bin/brew

if [ "$(id -u)" -eq 0 ]; then SUDO=; else SUDO=sudo; fi

case "$(uname -s)" in
	Darwin)
		if [ -n "$BREW" ]; then
			rpk action "$BREW" install stow
		else
			echo "depends/stow: brew not found" >&2
			exit 1
		fi
		;;
	Linux)
		if command -v apt-get >/dev/null 2>&1; then
			exec $SUDO apt-get install -y stow
		elif command -v dnf >/dev/null 2>&1; then
			exec $SUDO dnf install -y stow
		elif command -v yum >/dev/null 2>&1; then
			exec $SUDO yum install -y stow
		elif command -v pacman >/dev/null 2>&1; then
			exec $SUDO pacman -S --noconfirm stow
		elif command -v apk >/dev/null 2>&1; then
			exec $SUDO apk add stow
		else
			echo "depends/stow: no supported package manager" >&2
			exit 1
		fi
		;;
	*)
		echo "depends/stow: unsupported platform: $(uname -s)" >&2
		exit 1
		;;
esac
