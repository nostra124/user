#!/bin/sh
# Install dependency: git (system tool).
set -eu

command -v git >/dev/null 2>&1 && exit 0

if [ "$(id -u)" -eq 0 ]; then SUDO=; else SUDO=sudo; fi

case "$(uname -s)" in
	Darwin)
		command -v brew >/dev/null 2>&1 || {
			echo "depends/git: brew not found" >&2
			exit 1
		}
		exec brew install git
		;;
	Linux)
		if command -v apt-get >/dev/null 2>&1; then
			exec $SUDO apt-get install -y git
		elif command -v dnf >/dev/null 2>&1; then
			exec $SUDO dnf install -y git
		elif command -v yum >/dev/null 2>&1; then
			exec $SUDO yum install -y git
		elif command -v pacman >/dev/null 2>&1; then
			exec $SUDO pacman -S --noconfirm git
		elif command -v apk >/dev/null 2>&1; then
			exec $SUDO apk add git
		else
			echo "depends/git: no supported package manager" >&2
			exit 1
		fi
		;;
	*)
		echo "depends/git: unsupported platform: $(uname -s)" >&2
		exit 1
		;;
esac
