#!/bin/sh
# Verify dependency: rpk.
#
# rpk is the package manager itself. If this script is running,
# rpk invoked it, so rpk is on PATH by definition. Asking rpk to
# install rpk is nonsense; we only assert and bail out with a
# clear error if the invariant is somehow violated.
set -eu

command -v rpk >/dev/null 2>&1 || {
	echo "depends/rpk: rpk not on PATH (this should be impossible)" >&2
	exit 1
}

exit 0
