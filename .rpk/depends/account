#!/bin/sh
# Install dependency: account (rpk package).
#
# Invoke rpk in PACKAGE-FIRST form (`rpk account install`), NOT the
# verb-first form (`rpk install account`). rpk's argv parser auto-
# detects PACKAGE from the cwd's git worktree; this script runs with
# cwd inside user/.rpk/depends/, so `rpk install account` would be
# read as "install user, version=account", re-enter user's depends
# loop, and recurse indefinitely. The package-first form is matched
# by the first branch of rpk's dispatcher (looks $1 up in `rpk list`)
# and bypasses the cwd-based detection entirely.
set -eu

RPK="$HOME/.local/bin/rpk"

[ -x "$RPK" ] || {
	echo "depends/account: $RPK not found or not executable" >&2
	exit 1
}

# Idempotent import: register the bare repo if rpk doesn't know it yet.
"$RPK" list 2>/dev/null | grep -qx account \
	|| "$RPK" import https://github.com/nostra124/account

exec "$RPK" account install
