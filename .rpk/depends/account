#!/bin/sh
# Make the `account` rpk package available to rpk.
#
# This script's only job is to register the bare repo via
# `rpk import`. The actual `rpk install account` is rpk's own
# job once the dep is available — calling it from here causes
# rpk's transitive-dep loop to re-fire indefinitely.
set -eu

RPK="$HOME/.local/bin/rpk"

[ -x "$RPK" ] || {
	echo "depends/account: $RPK not found or not executable" >&2
	exit 1
}

# Idempotent: skip if already imported.
"$RPK" list 2>/dev/null | grep -qx account && exit 0

exec "$RPK" import https://github.com/nostra124/account
